<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Objective</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #000;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        .header {
            padding: 20px 40px;
        }

        .logo {
            height: 50px;
            max-width: 200px;
        }

        .login-container {
            display: flex;
            justify-content: center;
            align-items: center;
            flex: 1;
        }

        .login-form {
            background-color: #1a1a1a;
            padding: 40px;
            border-radius: 8px;
            box-shadow: 0 10px 40px rgba(255, 255, 255, 0.1);
            width: 100%;
            max-width: 400px;
        }

        .login-form h1 {
            color: #fff;
            margin-bottom: 30px;
            text-align: center;
            font-size: 24px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-group label {
            display: block;
            color: #ccc;
            margin-bottom: 8px;
            font-weight: 500;
        }

        .form-group input {
            width: 100%;
            padding: 12px;
            border: 1px solid #444;
            border-radius: 4px;
            background-color: #2a2a2a;
            color: #fff;
            font-size: 14px;
            transition: border-color 0.3s;
        }

        .form-group input:focus {
            outline: none;
            border-color: #0066cc;
        }

        .login-btn {
            width: 100%;
            padding: 12px;
            background-color: #0066cc;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.3s;
        }

        .login-btn:hover {
            background-color: #0052a3;
        }

        .login-btn:active {
            background-color: #003d7a;
        }

        .error-message {
            color: #ff4444;
            text-align: center;
            margin-top: 10px;
            font-size: 14px;
            display: none;
        }

        .success-screen {
            display: none;
            justify-content: center;
            align-items: center;
            flex: 1;
            flex-direction: column;
            text-align: center;
        }

        .success-message {
            color: #00cc66;
            font-size: 32px;
            margin-bottom: 30px;
            font-weight: 600;
        }

        .logout-btn {
            padding: 12px 30px;
            background-color: #0066cc;
            color: white;
            border: none;
            border-radius: 4px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background-color 0.3s;
        }

        .logout-btn:hover {
            background-color: #0052a3;
        }
    </style>
</head>
<body>
    <div class="header">
        <img src="https://www.objective.com.br/assets/logo-objective.svg" alt="Objective Logo" class="logo" onerror="this.style.display='none'">
    </div>

    <!-- Login Screen -->
    <div id="loginScreen" class="login-container">
        <form class="login-form" onsubmit="handleLogin(event)">
            <h1>Login</h1>
            <div class="form-group">
                <label for="usuario">Usuário</label>
                <input type="text" id="usuario" placeholder="admin" required>
            </div>
            <div class="form-group">
                <label for="senha">Senha</label>
                <input type="password" id="senha" placeholder="••••••••" required>
            </div>
            <button type="submit" class="login-btn">Entrar</button>
            <div class="error-message" id="errorMessage">Usuário ou senha inválidos</div>
        </form>
    </div>

    <!-- Success Screen -->
    <div id="successScreen" class="success-screen">
        <div class="success-message">✓ Você logou com sucesso</div>
        <button class="logout-btn" onclick="handleLogout()">Sair</button>
    </div>

    <script>
        function handleLogin(event) {
            event.preventDefault();

            const usuario = document.getElementById('usuario').value;
            const senha = document.getElementById('senha').value;
            const errorMessage = document.getElementById('errorMessage');

            if (usuario === 'admin' && senha === 'admin') {
                // Hide login screen and show success screen
                document.getElementById('loginScreen').style.display = 'none';
                document.getElementById('successScreen').style.display = 'flex';
                errorMessage.style.display = 'none';
            } else {
                // Show error message
                errorMessage.style.display = 'block';
                document.getElementById('senha').value = '';
            }
        }

        function handleLogout() {
            // Reset form
            document.getElementById('usuario').value = '';
            document.getElementById('senha').value = '';

            // Show login screen and hide success screen
            document.getElementById('loginScreen').style.display = 'flex';
            document.getElementById('successScreen').style.display = 'none';
        }
    </script>
</body>
</html>
